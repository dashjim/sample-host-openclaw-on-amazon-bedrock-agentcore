# AgentCore Starter Toolkit configuration
# Generated by `agentcore configure` — copy this file to .bedrock_agentcore.yaml
# and update the values marked with <...> for your environment.
#
# IMPORTANT: source_path MUST point to the bridge/ subdirectory, NOT the repo root.
# If CodeBuild fails with "not found" errors for agentcore-contract.js etc., fix source_path.

default_agent: openclaw_agent
agents:
  openclaw_agent:
    name: openclaw_agent
    language: typescript
    node_version: '20'
    entrypoint: <your-local-path>/bridge/Dockerfile
    deployment_type: container
    runtime_type: null
    platform: linux/arm64
    container_runtime: docker          # or finch/podman
    source_path: <your-local-path>/bridge   # <- MUST point to bridge/, NOT repo root!
    aws:
      execution_role: arn:aws:iam::<ACCOUNT_ID>:role/openclaw-agentcore-execution-role-us-west-2
      execution_role_auto_create: true
      account: '<ACCOUNT_ID>'
      region: us-west-2
      ecr_repository: <ACCOUNT_ID>.dkr.ecr.us-west-2.amazonaws.com/bedrock-agentcore-openclaw_agent
      ecr_auto_create: false
      s3_path: null
      s3_auto_create: false
      network_configuration:
        network_mode: VPC
        network_mode_config:
          security_groups:
          - <SECURITY_GROUP_ID>        # from CDK OpenClawAgentCore output
          subnets:
          - <PRIVATE_SUBNET_1>         # from CDK OpenClawVpc output
          - <PRIVATE_SUBNET_2>
      protocol_configuration:
        server_protocol: HTTP
      observability:
        enabled: true
      lifecycle_configuration:
        idle_runtime_session_timeout: 900    # 15 min idle timeout
        max_lifetime: 28800                   # 8 hour max session lifetime
    bedrock_agentcore:
      agent_id: null                   # populated after first `agentcore deploy`
      agent_arn: null
      agent_session_id: null
    codebuild:
      project_name: null               # populated after first `agentcore deploy`
      execution_role: null
      source_bucket: null
    memory:
      mode: STM_ONLY
      memory_id: null                  # populated after first `agentcore deploy`
      memory_arn: null
      memory_name: openclaw_agent_mem
      event_expiry_days: 30
      first_invoke_memory_check_done: false
      was_created_by_toolkit: false
    identity:
      credential_providers: []
      workload: null
    aws_jwt:
      enabled: false
      audiences: []
      signing_algorithm: ES384
      issuer_url: null
      duration_seconds: 300
    authorizer_configuration: null
    request_header_configuration: null
    oauth_configuration: null
    api_key_env_var_name: null
    api_key_credential_provider_name: null
    is_generated_by_agentcore_create: false
