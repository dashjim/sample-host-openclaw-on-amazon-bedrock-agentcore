# OpenClaw deployment environment overrides
# Copy this file to .env.deploy and fill in actual values.
# .env.deploy is gitignored — never commit it.
#
# Values here SUPPLEMENT the deploy script's auto-discovered env vars
# (from CDK stack outputs). Use this for values not in stack outputs.

# Bedrock model (overrides cdk.json default_model_id for the container)
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-6-v1

# Sub-agent model (overrides cdk.json subagent_model_id)
# SUBAGENT_BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-6-v1

# AgentCore Memory (from agentcore deploy output / .bedrock_agentcore.yaml)
# BEDROCK_AGENTCORE_MEMORY_ID=
# BEDROCK_AGENTCORE_MEMORY_NAME=openclaw_agent_mem

# Browser (from CDK OpenClawAgentCore stack output BrowserIdentifier)
# BROWSER_IDENTIFIER=

# Cognito (normally auto-discovered from stack outputs; override if needed)
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
